{
  "name": "kiosk-screensaver",
  "env": {
    "RAILS_SERVE_STATIC_FILES": { "value": "enabled" },
    "RAILS_LOG_TO_STDOUT": { "value": "true" },
    "RAILS_ENV": { "value": "production" },
    "SECRET_KEY_BASE": { "generator": "secret" }
  },
  "healthchecks": {
    "web": [
      {
        "type": "startup",
        "name": "web-ready-check",
        "path": "/up",
        "initialDelay": 5,
        "timeout": 5,
        "attempts": 3
      }
    ]
  },
  "dokku": {
    "plugins": [ "postgres" ]
  },
  "scripts": {
    "dokku": {
      "predeploy": "bundle exec rake db:migrate"
    }
  },
  "cron": [
    {
      "command": "bundle exec rake slides:expire",
      "schedule": "0 2 * * *"
    },
    {
      "command": "bundle exec rake slides:delete_expired",
      "schedule": "10 2 * * *"
    },
    {
      "command": "bundle exec rake kiosk_logs:purge_old",
      "schedule": "20 2 * * *"
    }
  ],
  "buildpacks": [
    { "url": "herokuk/nodejs" },
    { "url": "heroku/ruby" }
  ]
}
